# ─────────────────────────────────────────────
# backend-market/.env
# Copy this to .env and fill in your values.
# backend-market shares JWT_SECRET with backend-main
# so SmartArch tokens work across both services.
# ─────────────────────────────────────────────

# Server
MARKET_PORT=4000
NODE_ENV=development

# Must match backend-main JWT_SECRET exactly
JWT_SECRET=your_jwt_secret_here

# CORS — set to your frontend origin in production
CORS_ORIGIN=http://localhost:3000

# ── Optional real-data sources ──────────────────
# Leave blank to use the built-in simulation engine.

# RapidAPI key for Realty-in-US (US/Canada listings)
# Sign up at https://rapidapi.com/apidojo/api/realty-in-us
RAPIDAPI_KEY=

# Future: Zoopla UK, Idealista EU, 99acres IN, etc.
# ZOOPLA_KEY=
# IDEALISTA_KEY=
